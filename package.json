{
  "name": "@metricinsights/cs-helper",
  "version": "0.8.1-beta.1",
  "description": "Helper for Custom Scripts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "postinstall": "node scripts/sync-npm-bundled-patches.js",
    "prepare": "node scripts/sync-npm-bundled-patches.js",
    "clean:dist": "node scripts/clean-dist.cjs",
    "build": "npm run clean:dist && npm run build:sources && npm run build:bin",
    "postbuild": "npm pack && node scripts/postbuild.mjs",
    "build:sources": "tsc",
    "build:bin": "tsc --project tsconfig.bin.json && node scripts/chmod-bin.cjs",
    "test": "playwright test",
    "release": "semantic-release",
    "version": "npm version --commit-hooks false --git-tag-version false",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./dist/utils": {
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "utils": [
        "./dist/utils/index.d.ts"
      ],
      "dist/utils": [
        "./dist/utils/index.d.ts"
      ]
    }
  },
  "bin": {
    "cs-helper": "dist/bin/build.js",
    "cs-helper-create": "dist/bin/create.js"
  },
  "files": [
    "dist/",
    "scripts/sync-npm-bundled-patches.js",
    "templates",
    "ai-addons",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mi-examples/cs-helper.git"
  },
  "keywords": [
    "helper",
    "custom script",
    "Metric Insights",
    "MI",
    "MetricInsights"
  ],
  "author": "Serhii Shpak",
  "license": "ISC",
  "overrides": {
    "node": ">=22.0.0",
    "js-yaml": ">=4.2.0",
    "serialize-javascript": ">=7.0.3",
    "undici": ">=8.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jquery": "^3.5.34",
    "@types/promise-polyfill": "^6.0.6",
    "@types/prompts": "^2.4.9",
    "brace-expansion": "^5.0.6",
    "ip-address": "^10.2.0",
    "picomatch": "4.0.4",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "sigstore": "^4.1.1",
    "tar": "^7.5.16"
  },
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "babel-loader": "^10.1.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "isbinaryfile": "^6.0.0",
    "promise-polyfill": "8.3.0",
    "prompts": "^2.4.2",
    "string-includes-polyfill": "^1.0.6",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2"
  },
  "bugs": {
    "url": "https://github.com/mi-examples/cs-helper/issues"
  },
  "homepage": "https://github.com/mi-examples/cs-helper#readme"
}
